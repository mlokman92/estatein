# Copy this file to `.env.local` and fill in the values.
# The publishable/anon key is safe to ship in a client bundle — Row Level
# Security is what actually protects the data.

VITE_SUPABASE_URL=https://bogapwrqbgtqahegrwxy.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: the deployed URL of the public Next.js site (e.g. https://estatein.netlify.app).
# Used only to preview images whose src is a site-relative path like /images/pd-1.jpg.
# Leave blank if you don't need those previews.
VITE_SITE_URL=
